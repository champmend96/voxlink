# Database
DATABASE_URL=postgresql://voxlink:voxlink@localhost:5432/voxlink

# JWT
JWT_SECRET=change-me-to-a-secure-random-string
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string

# Server
PORT=3000
NODE_ENV=development

# TURN Server
TURN_SERVER=localhost
TURN_USERNAME=voxlink
TURN_PASSWORD=voxlink-turn-password

# Push Notifications — APNs (iOS)
APNS_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=

# Push Notifications — FCM (Android)
FCM_SERVICE_ACCOUNT_PATH=

# File Uploads
FILE_STORAGE_PATH=
MAX_FILE_SIZE=26214400

# Mediasoup (Group Calls)
MEDIASOUP_WORKERS=2
MEDIASOUP_RTC_MIN_PORT=40000
MEDIASOUP_RTC_MAX_PORT=49999
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=

# Security
CORS_ORIGINS=*
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000
