{
  "name": "voxlink",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "server",
    "mobile"
  ],
  "scripts": {
    "server:dev": "npm run dev --workspace=server",
    "server:build": "npm run build --workspace=server",
    "mobile:start": "npm run start --workspace=mobile",
    "test": "npm run test:server && npm run test:mobile",
    "test:server": "npm test --workspace=server",
    "test:mobile": "npm test --workspace=mobile",
    "test:server:unit": "npm run test:unit --workspace=server",
    "test:server:integration": "npm run test:integration --workspace=server",
    "test:coverage": "npm run test:coverage --workspace=server && npm run test:coverage --workspace=mobile",
    "test:watch": "npm run test:watch --workspace=server"
  }
}
